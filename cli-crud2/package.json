{
  "name": "crud-csharp",
  "version": "1.0.4",
  "description": "CLI tool to generate C# Controller structure using Plop",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "crud-csharp": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "csharp",
    "controller",
    "generator",
    "plop",
    "dotnet",
    "crud",
    "api"
  ],
  "author": "tainguyen.ntt.97@gmail.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/soilidokay/project-clis/blob/master/cli-crud2"
  },
  "homepage": "https://github.com/soilidokay/project-clis/blob/master/cli-crud2/README.md",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "npm run clean && tsc && npm run copy-templates",
    "start": "node dist/index.js",
    "dev": "ts-node --esm src/index.ts",
    "batch": "node dist/index.js --multiple",
    "clean": "rimraf dist",
    "copy-templates": "copyfiles -u 0 templates/**/* dist/",
    "test": "npm run build && npm run test-cli",
    "test-cli": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "minimist": "^1.2.8",
    "plop": "^3.1.2"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.10.0",
    "copyfiles": "^2.4.1",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
